
# Backend API Gateway (nginx)
EXPO_PUBLIC_API_BASE_URL=https://homeverse-bds.duckdns.org
EXPO_PUBLIC_API_FALLBACK_BASE_URL=
EXPO_PUBLIC_ENABLE_API_FALLBACK=false
# Property Service (nginx đã route, nhưng giữ lại cho backup)
EXPO_PUBLIC_PROPERTY_API_BASE_URL=https://homeverse-bds.duckdns.org
# Payment Service (nginx chỉ route /api/payment/, các endpoint khác gọi trực tiếp)
EXPO_PUBLIC_PAYMENT_API_BASE_URL=https://homeverse-bds.duckdns.org
# WebSocket (notification-service qua nginx)
EXPO_PUBLIC_WS_URL=https://homeverse-bds.duckdns.org/ws-notifier
EXPO_PUBLIC_WS_CHAT_URL=https://homeverse-bds.duckdns.org/ws-chat
EXPO_PUBLIC_WS_AI_URL=https://homeverse-bds.duckdns.org/ws-ai
# Google Maps API Key
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# Cloudinary (if uploading directly from mobile)
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_upload_preset
# App Configuration
EXPO_PUBLIC_APP_NAME=HomeVerse
EXPO_PUBLIC_APP_VERSION=1.0.0
